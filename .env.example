# Autenticación del dashboard
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia-esta-contraseña
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=string-aleatorio-largo-para-firmar-cookies

# YCloud WhatsApp API
YCLOUD_API_KEY=tu_api_key_de_ycloud
YCLOUD_PHONE_NUMBER=+5491155555555

# Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Solo para desarrollo local — NUNCA en producción
# SKIP_SIGNATURE_CHECK=true

# Backup automático a Google Drive (opcional pero recomendado)
# 1. Crear Service Account en Google Cloud Console
# 2. Habilitar Google Drive API
# 3. Descargar el JSON de la cuenta de servicio
# 4. Codificar en base64: base64 -i service-account.json
# 5. Compartir la carpeta de Drive con el email del service account
GOOGLE_SERVICE_ACCOUNT_KEY=base64-del-json-de-service-account
GOOGLE_DRIVE_BACKUP_FOLDER_ID=id-de-la-carpeta-en-drive
